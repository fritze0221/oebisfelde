FUNCTION_BLOCK "FB53_Mittelwert"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      Zeitfenster { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt := 60;
      Rohwert { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Real;
      Rohwert_nok { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
   END_VAR

   VAR_OUTPUT 
      Mittelwert { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Real;
   END_VAR

   VAR_IN_OUT 
      MemDB : "T_MW_MITTEL";
   END_VAR

   VAR 
      DataIdx_max { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
      curInIdx { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
      valid_Window { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
   END_VAR

   VAR_TEMP 
      i : Int;
      s : Real;
   END_VAR

   VAR CONSTANT 
      MaxEntries : Int := 120;
   END_VAR


BEGIN
	    IF #Zeitfenster <= 0 THEN
	        #DataIdx_max := 0;
	    ELSIF #Zeitfenster > #MaxEntries THEN
	        #DataIdx_max := #MaxEntries - 1;
	    ELSE
	        #DataIdx_max := DINT_TO_INT(#Zeitfenster) - 1;
	    END_IF;
	    IF #Rohwert_nok OR #DataIdx_max = 0 THEN
	        #curInIdx := 0;
	        #valid_Window := 0;
	        #Mittelwert := #Rohwert;
	    ELSE
	        
	        IF "Imp_Sek_Zyk_MW" THEN
	            #MemDB.Values[#curInIdx] := #Rohwert;
	            #curInIdx := #curInIdx + 1;
	            IF #curInIdx > #DataIdx_max THEN
	                #curInIdx := 0;
	            END_IF;
	            #s := 0.0;
	            FOR #i := 0 TO #valid_Window DO
	                #s := #s + #MemDB.Values[#i];
	            END_FOR;
	            #Mittelwert := #s / (INT_TO_REAL(#valid_Window + 1));
	            IF #valid_Window < #DataIdx_max THEN
	                #valid_Window := #valid_Window + 1;
	            ELSE
	                #valid_Window := #DataIdx_max;
	            END_IF;
	        END_IF;
	    END_IF;
	    
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB54_ZW"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_IN_OUT 
      PLS_Bef : "T_ZW_BEF";
   END_VAR

   VAR 
      ZW_int { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt;
      ZW_sub { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt;
      FM_Imp { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
   END_VAR


BEGIN
	
	IF #PLS_Bef.Reset THEN
	    #PLS_Bef.ZW_Vortag := #PLS_Bef.ZW_Tag;
	    #PLS_Bef.ZW_Tag := #ZW_sub;
	    #ZW_sub := 0;
	    #PLS_Bef.Reset := 0;
	END_IF;
	IF #PLS_Bef.Impuls AND NOT #FM_Imp THEN
	    #ZW_int := #ZW_int +1;
	    IF #ZW_int >= #PLS_Bef.Teiler THEN
	        #ZW_int := 0;
	        #PLS_Bef.ZW_raw := #PLS_Bef.ZW_raw + 1;
	        #ZW_sub := #ZW_sub + 1;
	    END_IF;
	END_IF;
	#FM_Imp := #PLS_Bef.Impuls;
	
	
	
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB78_ModbusOverIP_USV"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// Bausteinparameter
   VAR_INPUT 
      Rec_ok : Bool;
      Send_ok : Bool;
      Rec_Len : UDInt;
   END_VAR

   VAR_OUTPUT 
      Send_Req : Bool;
      Kom_St : Bool;
      Send_Len : UDInt;   // temporäre Variablen
   END_VAR

   VAR_IN_OUT 
      Cmd_Aux01 : Bool;
      Cmd_Aux02 : Bool;
   END_VAR

   VAR 
      Tmr_PollCycle {InstructionName := 'TON_TIME'; LibVersion := '1.0'} : TON_TIME;
      Tmr_ReqTimeOut {InstructionName := 'TON_TIME'; LibVersion := '1.0'} : TON_TIME;
      TimeOut_cnt : Int;
      TransActID_Cnt : Int;
      ReqIdx : Int;
      ReqIdx_Prio : Int;
      TlgCycle : Bool;
      ReqTimeSync : Bool;
      PrioCycle : Bool;
   END_VAR

   VAR_TEMP 
      i : Int;
      Data_Offs : Int;
      SR_TransActID : Int;
      SR_TransActID_Cnt : Int;
      SR_TlgLen : Int;
      SR_UnitID : Int;
      SR_FunctionCode : Int;
      SR_RegisterAdr : Int;
      SR_RegisterCount : Int;
      DB_Adr : Int;
      DB_Num : Word;
      w : Word;
      b : Byte;
      Rec_ok_save : Bool;
   END_VAR


BEGIN
	    #Tmr_PollCycle(IN := NOT #TlgCycle,
	                   PT := T#1s);
	    #Tmr_ReqTimeOut(IN := #TlgCycle,
	                    PT := T#4s);
	    IF #Tmr_ReqTimeOut.Q THEN
	        #TlgCycle := false;
	        #Send_Req := false;
	        IF (#TimeOut_cnt < 12) THEN
	            #TimeOut_cnt := #TimeOut_cnt + 1;
	        END_IF;
	    END_IF;
	    
	    IF #TimeOut_cnt >= 12 THEN
	        #Kom_St := true;
	    ELSE
	        #Kom_St := false;
	    END_IF;
	    #Rec_ok_save := #Rec_ok;
	    IF #Rec_ok_save THEN
	        //Header prüfen
	        #SR_TransActID := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[0]);
	        #SR_TransActID_Cnt := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[1]);
	        #SR_TlgLen := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[4]) * 256 + BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[5]) + 6;
	        IF #SR_TransActID >= 1 AND #SR_TransActID <= "DB61_USV_ModTCP_WorkData".REQCNT AND #Rec_Len = #SR_TlgLen THEN
	            #SR_UnitID := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[6]);
	            #SR_FunctionCode := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[7]);
	            #SR_RegisterCount := BYTE_TO_INT("DB59_USV_ModTCP_RCV".Data[8]) / 2; //hier Anzahl Datenbytes -> Registerzahl ist die Hälfte
	            IF "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].UnitID = #SR_UnitID AND "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].FunctionCode = #SR_FunctionCode
	                AND "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].RegisterCount = #SR_RegisterCount THEN //Prüfung ConID, function code und Bytelänge
	                //Telegrammauswertung -> Registerdaten in hinterlegte Sourceadressen kopieren
	                IF #SR_FunctionCode <= 4 THEN
	                    #DB_Num := INT_TO_WORD("DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SourceDB_Num);
	                    #DB_Adr := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SourceDB_ByteAdr;
	                    IF "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].QuadBytes THEN
	                        #SR_RegisterCount := #SR_RegisterCount / 2;//Hack für Doppelwortübertragung (2 Register als low/high-Wort)
	                    END_IF;
	                    FOR #i := 0 TO #SR_RegisterCount - 1 DO
	                        //wenn Diskrepanz bzgl. endianess -> hier die Bytes zuordnen/tauschen!
	                        //Modbus ist i.d.R. big endian, d.h. high-byte kommt zuerst im Telegramm -> Wörter mit Bitmeldungen müssen geswappt werden
	                        IF NOT "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].QuadBytes THEN
	                            #Data_Offs := 9 + #i * 2;   //WORD-Size
	                            IF NOT "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SwapBytes THEN
	                                //WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr] :="DB59_USV_ModTCP_RCV".DB[#Data_Offs];
	                                //WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr + 1] :="DB59_USV_ModTCP_RCV".DB[#Data_Offs+1];
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 1);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 1,
	                                     value := #b);
	                            ELSE
	                                //WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr] :="DB59_USV_ModTCP_RCV".DB[#Data_Offs+1];
	                                //WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr + 1] :="DB59_USV_ModTCP_RCV".DB[#Data_Offs];
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 1,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 1);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr,
	                                     value := #b);
	                            END_IF;
	                            #DB_Adr := #DB_Adr + 2; //sonst +2 
	                            
	                        ELSE
	                            #Data_Offs := 9 + #i * 4;   //<<DWORD-Size
	                            IF NOT "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SwapBytes THEN
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 1);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 1,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 2);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 2,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 3);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 3,
	                                     value := #b);
	                            ELSE
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 3,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 1);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 2,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 2);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr + 1,
	                                     value := #b);
	                                #b := PEEK(area := 16#84, dbNumber := 59, byteOffset := #Data_Offs + 3);
	                                POKE(area := 16#84,
	                                     dbNumber := #DB_Num,
	                                     byteOffset := #DB_Adr,
	                                     value := #b);
	                            END_IF;
	                            #DB_Adr := #DB_Adr + 4; //sonst +2 
	                        END_IF;
	                        
	                    END_FOR;
	                ELSE
	                    //Rückantwort nach Schreiben von Registern
	                    #Rec_ok_save := true;
	                END_IF;
	                
	            ELSE
	                #Rec_ok_save := false;
	            END_IF;
	        ELSE
	            #Rec_ok_save := false;
	        END_IF;
	        IF #Rec_ok_save THEN
	            #TimeOut_cnt := 0;
	        ELSE
	            IF (#TimeOut_cnt < 12) THEN
	                #TimeOut_cnt := #TimeOut_cnt + 1;
	            END_IF;
	        END_IF;
	        #TlgCycle := false;
	    END_IF;
	    
	    IF #Send_ok OR NOT #TlgCycle THEN
	        #Send_Req := false;
	    END_IF;
	    
	    //einmal täglich Zeitsync durchführen -> hier nicht implementiert
	    (*
	   IF ("akt_Std"=1 AND "akt_Min"=0 AND "akt_Sek"=0) THEN
	       ReqTimeSync:=true;
	   END_IF;
	   *)
	    
	    IF #Tmr_PollCycle.Q THEN
	        IF #TransActID_Cnt < 255 THEN
	            #TransActID_Cnt := #TransActID_Cnt + 1;
	        ELSE
	            #TransActID_Cnt := 1;
	        END_IF;
	        //Schreibrichtung nicht implementiert!!
	        IF #Cmd_Aux01 THEN
	            #ReqIdx := 9;
	            #Cmd_Aux01 := FALSE;
	        ELSIF #Cmd_Aux02 THEN
	            #ReqIdx := 9;
	            #Cmd_Aux02 := FALSE;
	        ELSIF #ReqTimeSync THEN
	            #ReqIdx := 10;
	        ELSE
	            //Tlg. mit Prio-ID (z.B. Status Melder) werden jeden 2. Zyklus abgefragt, alle anderen zyklisch
	            IF NOT #PrioCycle THEN
	                #PrioCycle := TRUE;
	                #SR_TransActID := #ReqIdx_Prio + 1;
	                IF #SR_TransActID > "DB61_USV_ModTCP_WorkData".REQCNT THEN
	                    #SR_TransActID := 1;
	                END_IF;
	                WHILE #SR_TransActID <> #ReqIdx_Prio DO
	                    IF "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].TransactID_Prio = #SR_TransActID THEN
	                        #ReqIdx_Prio := #SR_TransActID;
	                    ELSE
	                        #SR_TransActID := #SR_TransActID + 1;
	                        IF #SR_TransActID > "DB61_USV_ModTCP_WorkData".REQCNT THEN
	                            IF #ReqIdx_Prio = 0 THEN
	                                #SR_TransActID := 0;
	                            ELSE
	                                #SR_TransActID := 1;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                END_WHILE;
	                
	            ELSE
	                #PrioCycle := FALSE;
	                #SR_TransActID := #ReqIdx + 1;
	                IF #SR_TransActID > "DB61_USV_ModTCP_WorkData".REQCNT THEN
	                    #SR_TransActID := 1;
	                END_IF;
	                WHILE #SR_TransActID <> #ReqIdx DO
	                    IF "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].TransactID = #SR_TransActID THEN
	                        #ReqIdx := #SR_TransActID;
	                    ELSE
	                        #SR_TransActID := #SR_TransActID + 1;
	                        IF #SR_TransActID > "DB61_USV_ModTCP_WorkData".REQCNT THEN
	                            IF #ReqIdx = 0 THEN
	                                #SR_TransActID := 0;
	                            ELSE
	                                #SR_TransActID := 1;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                END_WHILE;
	                
	            END_IF;
	        END_IF;
	        IF #SR_TransActID > 0 THEN
	            #SR_UnitID := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].UnitID;
	            #SR_FunctionCode := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].FunctionCode;
	            #SR_RegisterAdr := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].RegisterAdr;
	            #SR_RegisterCount := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].RegisterCount;
	            #Send_Len := 12;
	            
	            "DB60_USV_ModTCP_SEND".Data[0] := INT_TO_BYTE(#SR_TransActID);
	            "DB60_USV_ModTCP_SEND".Data[1] := INT_TO_BYTE(#TransActID_Cnt);
	            "DB60_USV_ModTCP_SEND".Data[2] := 0;      //Protokoll-ID
	            "DB60_USV_ModTCP_SEND".Data[3] := 0;      //Protokoll-ID
	            //Länge Sendetelegramm am Ende eintragen -> s.u.
	            //"DB60_USV_ModTCP_SEND".Data[4]:=0;      //Data len Hi
	            //"DB60_USV_ModTCP_SEND".Data[5]:=INT_TO_BYTE(Send_Len-6);      //Data len Lo
	            "DB60_USV_ModTCP_SEND".Data[6] := INT_TO_BYTE(#SR_UnitID);      //Unit-ID
	            "DB60_USV_ModTCP_SEND".Data[7] := INT_TO_BYTE(#SR_FunctionCode);      //Functioncode
	            #w := INT_TO_WORD(#SR_RegisterAdr);
	            "DB60_USV_ModTCP_SEND".Data[8] := WORD_TO_BYTE(SHR(IN := #w, N := 8) AND 16#FF);      //Register Address Hi
	            "DB60_USV_ModTCP_SEND".Data[9] := WORD_TO_BYTE(#w AND 16#FF);      //Register Address Lo
	            IF #SR_FunctionCode > 4 THEN
	                //beim Schreiben von Registern wird ab hier Dateninhalt übergeben
	                #DB_Num := INT_TO_WORD("DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SourceDB_Num);
	                #DB_Adr := "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SourceDB_ByteAdr;
	                FOR #i := 0 TO #SR_RegisterCount - 1 DO
	                    #Data_Offs := 10 + #i * 2;
	                    //wenn Diskrepanz bzgl. endianess -> hier die Bytes zuordnen/tauschen!
	                    //Modbus ist i.d.R. big endian, d.h. high-byte kommt zuerst im Telegramm -> Wörter mit Bitmeldungen müssen geswappt werden
	                    IF "DB61_USV_ModTCP_WorkData".REQ[#SR_TransActID].SwapBytes THEN
	                        //"DB60_USV_ModTCP_SEND".DB[#Data_Offs + 1] := WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr];
	                        //"DB60_USV_ModTCP_SEND".DB[#Data_Offs] := WORD_TO_BLOCK_DB (#DB_Num).DB[#DB_Adr + 1];
	                        #b := PEEK(area := 16#84, dbNumber := #DB_Num, byteOffset := #DB_Adr);
	                        POKE(area := 16#84,
	                             dbNumber := 57,
	                             byteOffset := #Data_Offs + 1,
	                             value := #b);
	                        #b := PEEK(area := 16#84, dbNumber := #DB_Num, byteOffset := #DB_Adr+1);
	                        POKE(area := 16#84,
	                             dbNumber := 57,
	                             byteOffset := #Data_Offs,
	                             value := #b);
	                        
	                    ELSE
	                        //"DB60_USV_ModTCP_SEND".DB[#Data_Offs] := WORD_TO_BLOCK_DB(#DB_Num).DB[#DB_Adr];
	                        //"DB60_USV_ModTCP_SEND".DB[#Data_Offs + 1] := WORD_TO_BLOCK_DB (#DB_Num).DB[#DB_Adr + 1];
	                        #b := PEEK(area := 16#84, dbNumber := #DB_Num, byteOffset := #DB_Adr);
	                        POKE(area := 16#84,
	                             dbNumber := 57,
	                             byteOffset := #Data_Offs,
	                             value := #b);
	                        #b := PEEK(area := 16#84, dbNumber := #DB_Num, byteOffset := #DB_Adr+1);
	                        POKE(area := 16#84,
	                             dbNumber := 57,
	                             byteOffset := #Data_Offs+1,
	                             value := #b);
	                        
	                    END_IF;
	                END_FOR;
	                #Send_Len := INT_TO_UDINT( 10 + (#SR_RegisterCount * 2));
	            ELSE
	                //beim Auslesen von Registern wird nur angeforderte Registerzahl übergeben
	                #w := INT_TO_WORD(#SR_RegisterCount);
	                "DB60_USV_ModTCP_SEND".Data[10] := WORD_TO_BYTE(SHR(IN := #w, N := 8) AND 16#FF);           //Register Count Hi
	                "DB60_USV_ModTCP_SEND".Data[11] := WORD_TO_BYTE(#w AND 16#FF);      //Register Count Lo
	                #Send_Len := 12;
	            END_IF;
	            //Länge Telegramm und Ergänzung Header
	            #w := UDINT_TO_WORD(#Send_Len - 6);
	            "DB60_USV_ModTCP_SEND".Data[4] := WORD_TO_BYTE(SHR(IN := #w, N := 8) AND 16#FF);       //Tlg.Len(-6) Hi
	            "DB60_USV_ModTCP_SEND".Data[5] := WORD_TO_BYTE(#w AND 16#FF);                    //Tlg.Len(-6) Lo
	            
	            
	            #TlgCycle := true;
	            #Send_Req := true;
	        END_IF;
	    END_IF;
	    
	    
	    
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB90_FU_CIM_EA"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      DP_aktiv : Bool;
   END_VAR

   VAR_IN_OUT 
      EA_STD : "T_ANTRIEB_EA";
      EA : "T_EA_FU_CIM_DP";
      MELD : "T_ANTRIEB_MELD";
   END_VAR

   VAR 
      PM_Start { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
      Tmr_Reset {InstructionName := 'TOF_TIME'; LibVersion := '1.0'; ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : TOF_TIME;
   END_VAR


BEGIN
	
	//Eingangsebene
	#EA_STD.E.FU_St := #EA.E.STW.Fault;
	#EA_STD.E.FU := #EA.E.STW.Dosierung;
	#EA_STD.E.Bed_vOrt := NOT #EA.E.STW.ActRemoteAccess AND 0;
	
	#EA_STD.E.UeDr_St := (#EA.E.FltCode = 210);
	#EA_STD.E.UDr_St := (#EA.E.FltCode = 211);
	#EA_STD.E.UeLM_St := (#EA.E.FltCode = 51);
	#EA_STD.E.TL_St := (#EA.E.FltCode = 57);
	#EA_STD.E.Kom_DP_St := (#EA.E.FltCode = 15) OR NOT #DP_aktiv;
	#EA_STD.E.Kom_int_St := (#EA.E.FltCode = 152);
	#EA_STD.E.Wart_Wa := (#EA.E.WrnCode = 12) OR (#EA.E.WrnCode = 33);
	
	#MELD.SW_akt := #EA.E.MeasuredDosingCapacity;   //Dosiermenge in l/h
	
	
	//Ausgangsebene
	IF #EA_STD.A.Req_extern_B1 THEN
	    #PM_Start := 1;
	END_IF;
	IF NOT #EA_STD.A.Req_extern_B1 AND #EA.E.STW.ActualStartStop=1 THEN
	    #PM_Start := 0;
	END_IF;
	
	
	#EA.A.RemoteAccessReq :=#PM_Start ;
	#EA.A.FlowControlEnable := #PM_Start;
	#EA.A.ProfiWatchdogEnable := #PM_Start;
	
	#MELD.Status.BFR_Ein1 := NOT #EA.E.STW.ActRemoteAccess;
	
	IF #EA_STD.A.FU THEN
	    #EA.A.OperatingMode := 0;   //manual
	    #EA.A.ReqStartStop := 0;    //Start-Request
	    #EA.A.SetSetpointManual := #MELD.SW_out;
	ELSE
	    #EA.A.SetSetpointManual := 0.0;
	    #EA.A.ReqStartStop := 1;    //Stop-Request
	END_IF;
	
	
	
	
	#Tmr_Reset(IN:=#EA_STD.A.Quit_extern,
	           PT:=t#3s);
	
	IF #Tmr_Reset.Q THEN
	    #EA.A.ResetFault := 1;
	END_IF;
	IF NOT #Tmr_Reset.Q OR #EA.E.STW.ResetFaultAck THEN
	    #EA.A.ResetFault := 0;
	END_IF;
	
	
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB91_FU_KAESER_EA"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      DP_aktiv : Bool;
   END_VAR

   VAR_IN_OUT 
      EA_STD : "T_ANTRIEB_EA";
      EA : "T_EA_KAESER";
      MELD : "T_ANTRIEB_MELD";
   END_VAR

   VAR 
      PM_Start { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
      Tmr_Reset {InstructionName := 'TOF_TIME'; LibVersion := '1.0'; ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : TOF_TIME;
   END_VAR


BEGIN
	
	//Eingangsebene
	#EA_STD.E.FU_St := #EA.E.Msg_dig.xBS6;
	#EA_STD.E.FU := #EA.E.Msg_dig.xBS1;
	#EA_STD.E.Bed_vOrt := #EA_STD.E.Bed_vOrt OR #EA.E.Msg_dig.xBS4;
	#EA_STD.E.Aus := NOT #EA.E.Msg_dig.xBS5;
	
	#EA_STD.E.Kom_DP_St := NOT #DP_aktiv;
	#EA_STD.E.Wart_Wa := #EA.E.Msg_dig.xBS7;
	
	#MELD.SW_akt := UINT_TO_REAL(#EA.E.Blockdrehzahl);   //DZ nach Getriebe in 1/min
	#MELD.MW_I := INT_TO_REAL(#EA.E.FU_Strom) / 100.0;
	#MELD.MW_P := INT_TO_REAL(#EA.E.HM_Leistung) / 10.0;
	#MELD.EZ := UINT_TO_DINT(#EA.E.EZ_x1000) * DINT#1000+UINT_TO_DINT(#EA.E.EZ_x1);
	
	//Ausgangsebene
	IF #EA_STD.A.Req_extern_B1 THEN
	    #PM_Start := 1;
	END_IF;
	IF NOT #EA_STD.A.Req_extern_B1 THEN
	    #PM_Start := 0;
	END_IF;
	
	
	#EA.A.Cmd_b1.xBS48 :=#PM_Start ;
	
	#MELD.Status.BFR_Ein1 := NOT #EA.E.Msg_dig.xBS5;
	
	IF #EA_STD.A.FU OR #EA_STD.A.Req_extern_B1 THEN
	    #EA.A.Solldrehzahl_Block := REAL_TO_UINT(#MELD.SW_out);
	ELSE
	    #EA.A.Solldrehzahl_Block := 0;
	END_IF;
	
	
	
	
	#Tmr_Reset(IN:=#EA_STD.A.Quit_extern,
	           PT:=t#3s);
	
	IF #Tmr_Reset.Q THEN
	    #EA.A.Cmd_b1.xBS54 := 1;
	    #EA.A.Cmd_b1.xBS55 := 1;
	END_IF;
	IF NOT #Tmr_Reset.Q OR #EA.E.Msg_dig.xBS55 THEN
	    #EA.A.Cmd_b1.xBS54 := 0;
	    #EA.A.Cmd_b1.xBS55 := 0;
	END_IF;
	
	#EA.A.MasterMsgHeader := #EA.E.SlvMsgHeader;
	#EA.A.MasterMsgFooter := #EA.E.SlvMsgFooter;
	
END_FUNCTION_BLOCK

