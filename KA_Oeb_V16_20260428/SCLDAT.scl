FUNCTION "Allgemein" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_TEMP 
      retval : Int;
      b_tmp : Bool;
   END_VAR


BEGIN
	
	//Anlaufphase
	//
	
	IF "FirstScan" THEN
	    "SPS_Anlauf" := 0;
	    "DB92_OP_Data".SPS_Idx := "SPS_Idx_eigen";
	    "DB92_OP_Data".SPS_Idx_BitIdx := SHL(IN := BYTE#1, N := INT_TO_UINT("SPS_Idx_eigen"));
	END_IF;
	    
	
	"FC61_TON_s"(enable:="SPS_Anlauf",
	           Imp:="Imp_Sek",
	           TmrMax:=5,
	           TmrVar:="Tmr_Anlauf_AG",
	           Q:=#b_tmp);
	
	IF #b_tmp THEN
	    "Wiederanlauf" := 1;
	END_IF;
	IF NOT "SPS_Anlauf" THEN
	    "Wiederanlauf_NA_chk" := 1;
	END_IF;
	
	//Ablauf nach Netzwiederkehr
	//Zuweisung setzen!!
	"Notstrombetrieb" := 0;
	"Netzausfall" := ( ("ZEN_Meld".E_NSHV_NA OR NOT "ZEN_Meld".E_NSHV_LS_Aus) AND NOT "Notstrombetrieb")AND FALSE;
	"ZEN_Meld".ZEN_NA_res := "Netzausfall";
	
	//nach Freigabe Peripherie Netzausfallsignal berücksichtigen
	#b_tmp := NOT "Netzausfall";
	
	"FC61_TON_s"(enable := #b_tmp,
	           Imp := "Imp_Sek",
	           TmrMax := 30,
	           TmrVar := "Tmr_Netzwiederkehr",
	           Q := #b_tmp);
	
	IF ("Freigabe_Peripherie" AND NOT "Netzausfall") OR #b_tmp THEN
	    "Freigabe_Verbraucher" := 1;
	END_IF;
	
	//Erzeugung globaler Quittierimpuls
	//
	//"UV_DEK_Bef".KAW_DEK_BF_Quit OR ("UV_DEK_Bef_UV".KAW_DEK_BF_Quit AND "UV_DEK_Meld".KAW_DEK_Bed_aktiv)
	//
	"FC62_TOF_s"(enable:="ZEN_Bef".ZEN_Quit_BF,
	             Imp:="Imp_Sek",
	             TmrMax:=2,
	             TmrVar:="Tmr_GlobalQuit",
	             Q:="Global_Quit");
	//Quittierung Meldesystem OP triggern
	"DB92_OP_Data".MsgQuit := (("ZEN_Bef".ZEN_Quit_BF) AND "ZEN_Meld".ZEN_Bed_aktiv);
	
	
	"ZEN_Bef".ZEN_Quit_BF := 0;
	
	
	//Uhrzeitverwaltung
	//
	
	"IDB_FB51_Time"();
	
	
	
	//Abfrage DP-Teilnehmer nach SPS-Anlauf
	
	"FC61_TON_s"(enable := "Wiederanlauf",
	           Imp := "Imp_Sek",
	           TmrMax := 2,
	           TmrVar := "Tmr_Freigabe_Peripherie",
	           Q := #b_tmp);
	IF #b_tmp THEN
	    "Freigabe_Peripherie" := 1;
	    "Freigabe_Zyklus" := 1;
	    #retval:=DeviceStates(LADDR := 259, MODE := 4, STATE := "DB91_DP_aktiv".Tln);
	END_IF;
	
	
	
	
END_FUNCTION

FUNCTION_BLOCK "FB55_PulsPause"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      enable { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
      Pulszeit { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt;
      Pausenzeit { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt;
   END_VAR

   VAR_OUTPUT 
      Operation { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
   END_VAR

   VAR 
      Tmr_Zt_Puls {InstructionName := 'TON_TIME'; LibVersion := '1.0'; ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : TON_TIME;
      Tmr_Zt_Pause {InstructionName := 'TON_TIME'; LibVersion := '1.0'; ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : TON_TIME;
      aktiv { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
      FM_init { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
   END_VAR


BEGIN
	
	IF #enable AND #Pulszeit>0 AND #Pausenzeit>0 THEN
	    IF NOT #aktiv AND NOT #Tmr_Zt_Pause.Q THEN
	        #aktiv := 1;
	    END_IF;
	ELSE
	    #aktiv := 0;
	END_IF;
	#FM_init := #enable;
	
	#Tmr_Zt_Puls(IN:=#aktiv,
	             PT:=DINT_TO_TIME(#Pulszeit*DINT#1000));
	
	#Tmr_Zt_Pause(IN := #Tmr_Zt_Puls.Q,
	              PT := DINT_TO_TIME(#Pausenzeit * DINT#1000));
	
	IF #Tmr_Zt_Pause.Q THEN
	    #aktiv := 0;
	END_IF;
	#Operation := (#aktiv AND NOT #Tmr_Zt_Puls.Q) OR (#enable AND (#Pausenzeit = 0));
END_FUNCTION_BLOCK

FUNCTION_BLOCK "FB59_Mittelwert_imp"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      Zeitfenster { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : DInt := 60;
      Rohwert { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Real;
      Rohwert_nok { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
      Imp { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Bool;
   END_VAR

   VAR_OUTPUT 
      Mittelwert { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Real;
   END_VAR

   VAR_IN_OUT 
      MemDB : "T_MW_MITTEL";
   END_VAR

   VAR 
      DataIdx_max { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
      curInIdx { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
      valid_Window { ExternalAccessible := 'False'; ExternalVisible := 'False'; ExternalWritable := 'False'} : Int;
   END_VAR

   VAR_TEMP 
      i : Int;
      s : Real;
   END_VAR

   VAR CONSTANT 
      MaxEntries : Int := 120;
   END_VAR


BEGIN
	    IF #Zeitfenster <= 0 THEN
	        #DataIdx_max := 0;
	    ELSIF #Zeitfenster > #MaxEntries THEN
	        #DataIdx_max := #MaxEntries - 1;
	    ELSE
	        #DataIdx_max := DINT_TO_INT(#Zeitfenster) - 1;
	    END_IF;
	    IF #Rohwert_nok OR #DataIdx_max = 0 THEN
	        #curInIdx := 0;
	        #valid_Window := 0;
	        #Mittelwert := #Rohwert;
	    ELSE
	        
	        IF #Imp THEN
	            #MemDB.Values[#curInIdx] := #Rohwert;
	            #curInIdx := #curInIdx + 1;
	            IF #curInIdx > #DataIdx_max THEN
	                #curInIdx := 0;
	            END_IF;
	            #s := 0.0;
	            FOR #i := 0 TO #valid_Window DO
	                #s := #s + #MemDB.Values[#i];
	            END_FOR;
	            #Mittelwert := #s / (INT_TO_REAL(#valid_Window + 1));
	            IF #valid_Window < #DataIdx_max THEN
	                #valid_Window := #valid_Window + 1;
	            ELSE
	                #valid_Window := #DataIdx_max;
	            END_IF;
	        END_IF;
	    END_IF;
	    
END_FUNCTION_BLOCK

ORGANIZATION_BLOCK "Main"
TITLE = "Main Program Sweep (Cycle)"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

BEGIN
	
	
	"Allgemein"();
	"Peripherie"();
	
	IF "Freigabe_Zyklus" THEN
	    
	    "FB1_Antriebe_IDB"();
	    "FB2_Messwerte_IDB"();
	    "FB3_Automatik_Belebung_IDB"();
	    "FB4_Automatik_Biocos_IDB"();
	    "FB5_Automatik_Zulauf_Ablauf_IDB"();
	    
	    
	    "FB6_Kommunikation_IDB"();
	    "FB7_Pumpwerke_IDB"();
	    
	    "FB8_Leitstelle_IDB"();
	    "FB9_USV_Kom_IDB"();
	    
	END_IF;
	
	
	"SPS_Anlauf" := 1;
END_ORGANIZATION_BLOCK

