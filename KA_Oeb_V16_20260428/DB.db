{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
   STRUCT 
      REQCNT : Int;
      REQ : Array[1..10] of "T_MODBUSTCP_USV_REQ";
      REQ01 : Struct   // binär
         Reg000_l : Word;   // System - UPSStatus_BF
         Reg000_h : Word;   // System - UPSStatus_BF
         Reg002 : Int;   // System - UPSStatusChangeCause_EN
         Reg003 : DWord;   // System - MOG.OutletStatus_BF
         Reg005 : Int;   // System - Reserved []
