{ S7_Optimized_Access := 'FALSE' }
AUTHOR : SIE_GST
FAMILY : S7_IEC
NAME : P_NA_IM
VERSION : 1.6
   STRUCT 
      DB_Manag { ExternalVisible := 'False'} : Struct
         Pos_of_DB { ExternalVisible := 'False'} : Byte;   // reserved for future - do not change !
         No_of_all_DBs { ExternalVisible := 'False'} : Byte;   // reserved for future - do not change !
         DB_No_Act { ExternalVisible := 'False'} : Word;   // reserved for future - do not change !
         DB_No_Prev { ExternalVisible := 'False'} : Word;   // reserved for future - do not change !
         DB_No_Next { ExternalVisible := 'False'} : Word;   // reserved for future - do not change !
         Reserved { ExternalVisible := 'False'} : Word;
      END_STRUCT;
      Info_Manag { ExternalVisible := 'False'} : Struct
         P_Byte_First_Info { ExternalVisible := 'False'} : Int;   // (Byte-) Position of first Para-Block - do not change !
         No_of_Infos { ExternalVisible := 'False'} : Int;   // 0:unspecified (DB is filled up to the end); otherwise size n of ARRAY [1..n]
         Len_Info { ExternalVisible := 'False'} : USInt;   // Difference in [byte] between two Para-Blocks - do not change !
         Len_Sort_Key { ExternalVisible := 'False'} : USInt;   // 0: without sorting; >0: Data sets are sorted ascending with x bytes
         Re_internal_usage { ExternalVisible := 'False'} : DWord;
      END_STRUCT;
      Global { ExternalVisible := 'False'} : Struct
         Para_DB_Type { ExternalVisible := 'False'} : Word;   // Internal identifier for this Data Block - do not change
         Image_Type { ExternalVisible := 'False'} : Byte;   // 1 Bit-Image, 2 IEC-Image, 3 IEC+Ext_State+Time
         Image_Len { ExternalVisible := 'False'} : Byte;   // 0: auto (standard); <> 0: fixed distance [Bit] of procesimages
         Subst_on_Error { ExternalVisible := 'False'} : Bool;   // Substitute values in case of connection errors ?
         Subst_Value { ExternalVisible := 'False'} : DWord;   // Substitute value (if activated). For SP only 0 and 1 possible
         Internal_10 { ExternalVisible := 'False'} : Word;   // Internal use: Last found parablock - do not change !
         Internal_12 { ExternalVisible := 'False'} : Word;   // Internal use: Last processed info - do not change !
      END_STRUCT;
      Para { ExternalVisible := 'False'} : Array[1..150] of Struct
         S_Line { ExternalVisible := 'False'} : Int;   // Source (Quelle): No of Line (Nr der Linie) (1..x)-actually do not change from 1
         S_ASDU { ExternalVisible := 'False'} : UInt;   // Source (Quelle): Address of ASDU (ASDU-Adresse)
         S_Info { ExternalVisible := 'False'} : DInt;   // Source (Quelle): Address of Infoobject (IOA)
         D_DB_No { ExternalVisible := 'False'} : Int;   // Dest. (Ziel) No. of DataBlock, 0 -> PIQ (PAA)
         D_Address { ExternalVisible := 'False'} : DInt;   // Dest. (Ziel): Bitposition
         P_No_of_fol_Infos { ExternalVisible := 'False'} : Int;   // Parameter: Number of following sequ. Infoelements
      END_STRUCT;
   END_STRUCT;


