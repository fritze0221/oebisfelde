         ASDU_Address { ExternalVisible := 'False'} : DInt;   // Parameter: ASDU address
         Link_Para_DB { ExternalVisible := 'False'} : Int;   // Parameter: associated link db no / 0 -> direct (no link db available)
         Link_Para_Pos { ExternalVisible := 'False'} : Int;   // Parameter: parablock no in link db
         Error { ExternalVisible := 'False'} : Bool;   // internal
         Res_1 { ExternalVisible := 'False'} : Byte;   // internal
         Res_2 { ExternalVisible := 'False'} : DInt;   // internal
         Res_3 { ExternalVisible := 'False'} : Int;   // internal
      END_STRUCT;
   END_STRUCT;


