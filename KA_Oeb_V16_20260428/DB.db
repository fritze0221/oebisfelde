         Reg008 : Int;   // System - Reserved []
         Reg009 : DWord;   // System - SOG[1].OutletStatus_BF
         Reg011 : Int;   // System - Reserved []
         Reg012 : DWord;   // System - SOG[2].OutletStatus_BF [Bitfeld]
         Reg014 : Int;   // System - Reserved []
         Reg015 : Int;   // System - Reserved []
         Reg016 : Int;   // System - Reserved []
         Reg017 : Int;   // System - Reserved []
         Reg018 : Word;   // System - SimpleSignalingStatus_BF
         Reg019 : Word;   // System - GeneralError_BF
         Reg020 : DWord;   // System - PowerSystemError_BF [Bitfeld]
         Reg022 : Word;   // System - BatterySystemError_BF
         Reg023 : Word;   // System - ReplaceBatteryTestStatus_BF
         Reg024 : Word;   // System - RunTimeCalibrationStatus_BF
         Reg025 : Word;   // System - Battery.LifeTimeStatus_BF
         Reg026 : Word;   // System - UserInterfaceStatus_BF
      END_STRUCT;
      REQ02 : Struct   // analog
         Reg128 : DInt;   // System - RunTimeRemaining [s]
         Reg130 : Int;   // System - StateOfCharge_Pct [%]
         Reg131 : Int;   // System - Battery.Positive.VoltageDC [V]
         Reg132 : Int;   // System - Battery.Negative.VoltageDC [V]
         Reg133 : Int;   // System - Battery.Date []
         Reg134 : Int;   // System - Reserved []
         Reg135 : Int;   // System - Battery.Temperature [°C]
         Reg136 : Int;   // System - Output[0].RealPower_Pct [%]
         Reg137 : Int;   // System - Output[1].RealPower_Pct [%]
         Reg138 : Int;   // System - Output[0].ApparentPower_Pct [%]
         Reg139 : Int;   // System - Output[1].ApparentPower_Pct [%]
         Reg140 : Int;   // System - Output[0].CurrentAC [A]
         Reg141 : Int;   // System - Output[1].CurrentAC [A]
         Reg142 : Int;   // System - Output[0].VoltageAC [V]
         Reg143 : Int;   // System - Output[1].VoltageAC [V]
         Reg144 : Int;   // System - Output.Frequency [Hz]
         Reg145 : DInt;   // System - Output.Energy [Wh]
         Reg147 : Int;   // System - Bypass.InputStatus_BF [Bitfeld]
         Reg148 : Int;   // System - Bypass.VoltageAC [V]
         Reg149 : Int;   // System - Bypass.Frequency [Hz]
         Reg150 : Int;   // System - Input.InputStatus_BF [Bitfeld]
         Reg151 : Int;   // System - Input[0].VoltageAC [V]
         Reg152 : Int;   // System - Input[1].VoltageAC [V]
         Reg153 : Int;   // System - Input[2].VoltageAC [V]
         Reg154 : Int;   // System - Efficiency_EN [enum]
         Reg155 : Int;   // System - MOG.TurnOffCountdown_EN [enum]
         Reg156 : Int;   // System - MOG.TurnOnCountdown_EN [enum]
         Reg157 : DInt;   // System - MOG.StayOffCountdown_EN [enum]
         Reg159 : Int;   // System - SOG[0].TurnOffCountdown_EN [enum]
         Reg160 : Int;   // System - SOG[0].TurnOnCountdown_EN [enum]
         Reg161 : DInt;   // System - SOG[0].StayOffCountdown_EN [enum]
         Reg163 : Int;   // System - SOG[1].TurnOffCountdown_EN [enum]
         Reg164 : Int;   // System - SOG[1].TurnOnCountdown_EN [enum]
         Reg165 : DInt;   // System - SOG[1].StayOffCountdown_EN [enum]
         Reg167 : Int;   // System - SOG[2].TurnOffCountdown_EN [enum]
         Reg168 : Int;   // System - SOG[2].TurnOnCountdown_EN [enum]
         Reg169 : DInt;   // System - SOG[2].StayOffCountdown_EN [enum]
      END_STRUCT;
   END_STRUCT;


BEGIN
   REQCNT := 2;
   REQ[1].TransactID := 1;
   REQ[1].UnitID := 1;
   REQ[1].FunctionCode := 3;
   REQ[1].RegisterCount := 27;
   REQ[1].SourceDB_Num := 61;
   REQ[1].SourceDB_ByteAdr := 182;
   REQ[1].SwapBytes := TRUE;
   REQ[2].TransactID := 2;
   REQ[2].UnitID := 1;
   REQ[2].FunctionCode := 3;
   REQ[2].RegisterAdr := 128;
   REQ[2].RegisterCount := 43;
   REQ[2].SourceDB_Num := 61;
