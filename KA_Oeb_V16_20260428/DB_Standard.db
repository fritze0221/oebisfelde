DATA_BLOCK "DB92_OP_Data"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
NON_RETAIN
   STRUCT 
      LocTime {InstructionName := 'DTL'; LibVersion := '1.0'} : DTL;
      tm_Array : Array[0..11] of Byte;
      Msg_B0 : Array[0..63] of Word;
      CtrlJob : Array[0..3] of Word;   // Steuerungsauftragsfach
      PicNum : Array[0..4] of Word;   // Steuerungsauftragsfach
      SPS_Idx : Int;   // Index eigene SPS
      Antr_Idx : Int;   // Index ausgewählter Antrieb für Anzeige/Bedienung
      Antr_Typ : Int;   // Typ ausgewählter Antrieb für Anzeige/Bedienung
      UserPrio : Int;   // Prio 0 - keine Bedienung, Prio 1 - Antrieb einzel, Prio 2 - alle Antriebe auf Bed. UV, Prio 3 - Parametrierung
      Antr_loc_prev : Bool;   // vorhergehenden (lokal) Antrieb in Panel-Auswahl anzeigen
      Antr_loc_next : Bool;   // nächsten Antrieb (lokal) in Panel-Auswahl anzeigen
      Antr_rem_prev : Bool;   // vorhergehenden (fern) Antrieb in Panel-Auswahl anzeigen
      Antr_rem_next : Bool;   // nächsten Antrieb (fern) in Panel-Auswahl anzeigen
      UserChg : Bool;   // Panelbenutzer hat gewechselt -> remote login prüfen
      PicSet_Antr_Menu : Bool;   // UV spezifisches Menü Antriebe aufrufen
      PicSet_Antr_Prm : Bool;   // Parameterbild zum gewählten Antrieb aufrufen
      MsgQuit : Bool;   // Quittierung Meldesystem
      Antr_Text_Idx_vis : Int;   // Textlisten für Bezeichnungen - Index für Auswahl Subliste 0..3
      Antr_Text_Idx_W0 : DWord;   // Textlisten für Bezeichnungen - Subliste 0
      Antr_Text_Idx_W1 : DWord;   // Textlisten für Bezeichnungen - Subliste 1
      Antr_Text_Idx_W2 : DWord;   // Textlisten für Bezeichnungen - Subliste 2
      Antr_Text_Idx_W3 : DWord;   // Textlisten für Bezeichnungen - Subliste 3
      UserID_BitIdx : DWord;   // Benutzerkennung bitweise, ID1=Bit 1 usw.
      Antr_UV_Idx : Byte;   // Index UV des gewählten Antriebs -> Anzeige, wenn nicht in eigener SPS abgearbeitet
      SPS_Idx_BitIdx : Byte;   // Index eigene SPS - Bitliste
      Antr_UV_rem : Bool;   // Hinweisfeld, wenn Antrieb in remoter SPS bearbeitet wird
      Antr_Bed_Sperr_0 : Array[0..63] of Bool;
      Antr_Bed_Sperr_1 : Array[0..63] of Bool;
      Bed_NHV : Array[1..128] of Bool;   // Bedienberechtigungen für (ferne) OP Bedienung
      activeUserGroup : Int;
   END_STRUCT;


BEGIN

END_DATA_BLOCK

